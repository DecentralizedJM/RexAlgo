# Docker Compose — copy to repo root as `.env` before `docker compose up`
JWT_SECRET=generate-with-openssl-rand-hex-32
ENCRYPTION_KEY=use-a-strong-random-passphrase-not-this-example

# Postgres for the full-stack compose (not the local-dev compose).
# If running docker-compose.yml as-is with a Postgres service, this will be set for you.
DATABASE_URL=postgres://rexalgo:rexalgo@postgres:5432/rexalgo

# Admin allowlist (comma-separated emails) — grants /admin access and master-studio approval rights.
ADMIN_EMAILS=

# Public API URL (no trailing slash). Master studio + Strategy studio + TV Webhooks show full webhook URLs.
# Production: https://api.rexalgo.xyz
# PUBLIC_API_URL=

# Legacy alias kept for backward compatibility.
# PUBLIC_APP_URL=

# Telegram bot (optional; Phase 6).
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_USERNAME=

# Browser session length in days (default 90, max 90)
# REXALGO_SESSION_MAX_AGE_DAYS=90

# Host port for nginx (UI + proxied /api). Use 8080 if binding :80 needs sudo
HOST_PORT=80
