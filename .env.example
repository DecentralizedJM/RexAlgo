# Docker Compose — copy to repo root as `.env` before `docker compose up`
JWT_SECRET=generate-with-openssl-rand-hex-32
ENCRYPTION_KEY=use-a-strong-random-passphrase-not-this-example

# Public URL of the API (no trailing slash) — Master studio + Strategy studio show full webhook URLs
# PUBLIC_APP_URL=https://your-domain.com

# Host port for nginx (UI + proxied /api). Use 8080 if binding :80 needs sudo
HOST_PORT=80
