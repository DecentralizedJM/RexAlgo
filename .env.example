# Docker Compose — copy to repo root as `.env` before `docker compose up`
JWT_SECRET=generate-with-openssl-rand-hex-32
ENCRYPTION_KEY=use-a-strong-random-passphrase-not-this-example

# Postgres for the full-stack compose (not the local-dev compose).
# If running docker-compose.yml as-is with a Postgres service, this will be set for you.
DATABASE_URL=postgres://rexalgo:rexalgo@postgres:5432/rexalgo

# Admin allowlist (comma-separated emails) — grants /admin access and master-studio approval rights.
ADMIN_EMAILS=
# Optional direct Telegram fan-out for admin alerts (comma-separated chat IDs).
# Useful if admins have not yet linked Telegram inside RexAlgo.
# ADMIN_TELEGRAM_CHAT_IDS=123456789,987654321

# Public API URL (no trailing slash). Master studio + Strategy studio + TV Webhooks show full webhook URLs.
# If the browser uses Vercel + /api rewrites to Railway, use that public origin (e.g. https://rexalgo.xyz).
# PUBLIC_API_URL=

# Legacy alias kept for backward compatibility (same value as PUBLIC_API_URL for most deployments).
# PUBLIC_APP_URL=

# Telegram bot.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_USERNAME=
# Shared secret validated against X-Telegram-Bot-Api-Secret-Token on the
# /api/telegram/webhook route. Generate with `openssl rand -hex 32` and pass
# `secret_token=<value>` when calling setWebhook.
# TELEGRAM_WEBHOOK_SECRET=

# Browser session length in days (default 90, max 90)
# REXALGO_SESSION_MAX_AGE_DAYS=90

# Host port for nginx (UI + proxied /api). Use 8080 if binding :80 needs sudo
HOST_PORT=80
