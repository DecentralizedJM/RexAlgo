%% RexAlgo — Mermaid diagram source (blocks mirror README Architecture section)
%% Narrative + tables: README.md | Metadata: repo/project.json

%% --- System context ---
flowchart TB
  subgraph actors [Actors]
    U[Trader / user]
    B[External bots\nTradingView / custom]
  end
  subgraph rexalgo [RexAlgo deployment]
    APP[Vite UI + Next API]
    PG[(PostgreSQL)]
    RD[(Redis\noptional)]
  end
  subgraph external [External]
    MR[Mudrex Futures API]
    TG[Telegram Bot API]
  end
  U -->|HTTPS same-origin /api| APP
  B -->|HTTPS signed webhooks| APP
  APP --> PG
  APP -.->|rate limits / shared state| RD
  APP --> MR
  APP --> TG

